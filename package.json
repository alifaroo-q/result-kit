{
  "name": "@zireal/result-kit",
  "version": "1.2.0",
  "description": "Type-safe result and structured error utilities for TypeScript, with optional NestJS adapters.",
  "license": "MIT",
  "author": "Ali Farooq <alifarooq122@gmail.com>",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alifarooq-zk/result-kit.git"
  },
  "keywords": [
    "result",
    "error-handling",
    "result-type",
    "result monad"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist coverage",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.19.15",
    "publint": "^0.3.18",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.12"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  }
}
