{
  "name": "@zireal/result-kit",
  "version": "5.3.0",
  "description": "Type-safe result and structured error utilities for TypeScript. Zero-dependency, ESM-only.",
  "license": "MIT",
  "author": "Ali Farooq <alifarooq122@gmail.com>",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alifaroo-q/result-kit.git"
  },
  "bugs": {
    "url": "https://github.com/alifaroo-q/result-kit/issues"
  },
  "homepage": "https://github.com/alifaroo-q/result-kit#readme",
  "keywords": [
    "result",
    "error-handling",
    "result-type",
    "result monad"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist coverage",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "publint": "^0.3.21",
    "tsdown": "^0.22.13",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fluent": {
      "types": "./dist/fluent/index.d.ts",
      "default": "./dist/fluent/index.js"
    },
    "./package.json": "./package.json"
  }
}
